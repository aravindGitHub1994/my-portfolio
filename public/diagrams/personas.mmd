flowchart TD
  DATA["Nemotron persona dataset<br/>synthetic, privacy-safe"]
  SELECT["Segment / OCEAN selection"]
  SIM["LLM persona simulation"]
  MKT["Marketing use cases<br/>messaging &amp; segmentation tests"]
